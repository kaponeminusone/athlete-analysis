# Copiar a Colab Secrets / celda Config / Vercel env

# --- Colab / motor ---
HOPLAB_DATA_ROOT=/content/drive/MyDrive/hoplab-data
HOPLAB_ENGINE_DIR=/content/hoplab-engine
HOPLAB_OUTPUT_ROOT=/content/drive/MyDrive/hoplab-data/output
HOPLAB_VIDEO_ROOT=/content/drive/MyDrive/hoplab-data/videos
HOPLAB_VENUE_ROOT=/content/drive/MyDrive/hoplab-data/venues
TJ_WRITE_ANNOTATED=0
TJ_PERSIST_FRAMES=1
API_PORT=8000

# Repo a clonar en cada sesión (ajustar cuando esté en GitHub)
# HOPLAB_REPO_URL=https://github.com/<org>/<repo>.git
# HOPLAB_REPO_BRANCH=master

# --- Web (Vercel) ---
# Dejar vacío si usas “Conectar motor” en la UI
VITE_API_BASE=
